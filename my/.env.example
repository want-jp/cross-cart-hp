# HMAC secret — must match between URL generation (n8n) and this app
TRACKING_HMAC_SECRET=change-me-to-a-random-string

# GCP / BigQuery (not needed when USE_MOCK_DATA=true)
GCP_PROJECT=your-gcp-project-id
BQ_DATASET=your-bq-dataset

# n8n (Phase 2 — not needed for MVP)
N8N_WEBHOOK_URL=
N8N_API_KEY=

# App
USE_MOCK_DATA=true
CONTACT_EMAIL=support@cross-cart.jp
